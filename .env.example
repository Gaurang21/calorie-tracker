VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI provider — set to 'ollama' or 'groq'. Defaults to ollama.
VITE_AI_PROVIDER=ollama

# Ollama (self-hosted on Oracle Cloud or local).
VITE_OLLAMA_URL=https://your-oracle-ip-or-domain
VITE_OLLAMA_API_KEY=your-secret-api-key-here

# Groq (free hosted Llama API). Sign up at console.groq.com.
VITE_GROQ_API_KEY=gsk_your_groq_key
# Optional overrides (sensible defaults baked in):
# VITE_GROQ_URL=https://api.groq.com/openai/v1
# VITE_GROQ_MODEL=llama-3.1-8b-instant
